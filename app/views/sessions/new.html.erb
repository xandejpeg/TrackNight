<div class="w-full max-w-sm">
  <div class="text-center mb-8">
    <span class="inline-grid place-items-center w-16 h-16 rounded-2xl bg-gradient-to-br from-race to-[#7a0a06] font-black italic text-3xl text-white shadow-[0_0_40px_rgba(225,6,0,0.55)]">X</span>
    <h1 class="mt-4 text-2xl font-black tracking-tight">TRACK<span class="text-race">NIGHT</span></h1>
    <p class="text-[10px] tracking-[0.35em] text-mute uppercase mt-1">Xande Racing Performance</p>
  </div>

  <div class="glass p-7">
    <% if flash[:alert] %>
      <p class="text-race-glow text-sm mb-4"><%= flash[:alert] %></p>
    <% end %>
    <%= form_with url: login_path, local: true, class: "space-y-4" do %>
      <div>
        <label class="kicker block mb-1.5">Piloto</label>
        <%= text_field_tag :username, params[:username], class: "field", autofocus: true, autocomplete: "username", placeholder: "Usuário" %>
      </div>
      <div>
        <label class="kicker block mb-1.5">Senha</label>
        <%= password_field_tag :password, nil, class: "field", autocomplete: "current-password", placeholder: "••••••" %>
      </div>
      <%= submit_tag "Entrar no grid", class: "btn-race w-full cursor-pointer" %>
    <% end %>
  </div>

  <p class="text-center text-[11px] text-mute mt-6">Kartódromo Granja Viana · Circuito 101</p>
</div>
